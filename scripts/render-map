#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_dottrace-common"

usage() {
  cat <<'USAGE'
Usage: scripts/render-map [options]

Render one project-scoped map from a DotTrace SQLite cache.

Options:
  --db <path>        SQLite cache path. Default: trace.db
  --project <value>  Project id, name, assembly, or path. Default: DotTrace.Cli
  --format <value>   Output format: text or html. Default: text
  --out <path>       Output path. Default: artifacts/maps/<project>.map.txt|html
  --snapshot <id>    Snapshot id to render. Default: active snapshot
  --max-depth <n>    Maximum tree depth. Default: CLI default
  --no-color         Disable terminal color in text output.
  -h, --help         Show this help.
USAGE
}

db_path="trace.db"
project="DotTrace.Cli"
format="text"
out_path=""
snapshot_id=""
max_depth=""
no_color=false

while (($#)); do
  case "$1" in
    --db)
      shift
      dottrace_require_value "--db" "${1:-}"
      db_path="$1"
      ;;
    --project)
      shift
      dottrace_require_value "--project" "${1:-}"
      project="$1"
      ;;
    --format)
      shift
      dottrace_require_value "--format" "${1:-}"
      format="$1"
      ;;
    --out)
      shift
      dottrace_require_value "--out" "${1:-}"
      out_path="$1"
      ;;
    --snapshot)
      shift
      dottrace_require_value "--snapshot" "${1:-}"
      snapshot_id="$1"
      ;;
    --max-depth)
      shift
      dottrace_require_value "--max-depth" "${1:-}"
      max_depth="$1"
      ;;
    --no-color)
      no_color=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      dottrace_die "unknown argument '$1'"
      ;;
  esac
  shift
done

case "$format" in
  text|html)
    ;;
  *)
    dottrace_die "--format must be text or html"
    ;;
esac

if [[ -z "$out_path" ]]; then
  safe_project="${project//\//_}"
  safe_project="${safe_project// /_}"
  safe_project="${safe_project//:/_}"
  extension="$format"
  if [[ "$format" == "text" ]]; then
    extension="txt"
  fi
  out_path="artifacts/maps/$safe_project.map.$extension"
fi

dottrace_cd_repo_root
mkdir -p -- "$(dirname -- "$out_path")"

args=(map --db "$db_path" --project "$project" --format "$format" --out "$out_path")

if [[ -n "$snapshot_id" ]]; then
  args+=(--snapshot "$snapshot_id")
fi

if [[ -n "$max_depth" ]]; then
  args+=(--max-depth "$max_depth")
fi

if [[ "$no_color" == true ]]; then
  args+=(--no-color)
fi

dottrace_cli "${args[@]}"
