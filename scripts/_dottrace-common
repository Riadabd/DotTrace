#!/usr/bin/env bash

set -euo pipefail

dottrace_repo_root() {
  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  cd -- "$script_dir/.." && pwd
}

dottrace_cd_repo_root() {
  cd -- "$(dottrace_repo_root)"
}

dottrace_cli() {
  dotnet run --project src/DotTrace.Cli -- "$@"
}

dottrace_die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

dottrace_require_value() {
  local option="$1"
  local value="${2:-}"

  if [[ -z "$value" ]]; then
    dottrace_die "$option requires a value"
  fi
}
