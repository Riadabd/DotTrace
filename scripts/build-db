#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_dottrace-common"

usage() {
  cat <<'USAGE'
Usage: scripts/build-db [options]

Build a DotTrace SQLite cache snapshot.

Options:
  --input <path>  Solution or project to analyze. Default: DotTrace.sln
  --db <path>     SQLite cache path. Default: trace.db
  -h, --help      Show this help.
USAGE
}

input_path="DotTrace.sln"
db_path="trace.db"

while (($#)); do
  case "$1" in
    --input)
      shift
      dottrace_require_value "--input" "${1:-}"
      input_path="$1"
      ;;
    --db)
      shift
      dottrace_require_value "--db" "${1:-}"
      db_path="$1"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      dottrace_die "unknown argument '$1'"
      ;;
  esac
  shift
done

dottrace_cd_repo_root
dottrace_cli cache build "$input_path" --db "$db_path"
